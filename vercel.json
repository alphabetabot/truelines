{
  "functions": {
    "api/log-results.js": {
      "maxDuration": 60
    },
    "api/picks-status.js": {
      "maxDuration": 30
    },
    "api/cron-newsletter.js": {
      "maxDuration": 300
    }
  },
  "redirects": [
    {
      "source": "/api/:path*",
      "has": [{ "type": "host", "value": "trueoddsiq.com" }],
      "destination": "https://www.trueoddsiq.com/api/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/cron-midday-post", "destination": "/api/cron-posts" },
    { "source": "/api/cron-evening-post", "destination": "/api/cron-posts?evening=true" },
    { "source": "/api/billing", "destination": "/api/picks-status" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/log-results", "schedule": "30 12 * * *" },
    { "path": "/api/log-results", "schedule": "30 18 * * *" },
    { "path": "/api/log-results", "schedule": "0 5 * * *" },
    { "path": "/api/cron-blogs", "schedule": "0 7 * * *" },
    { "path": "/api/cron-blogs?weekly=true", "schedule": "0 8 * * 1" },
    { "path": "/api/cron-posts", "schedule": "0 12 * * *" },
    { "path": "/api/cron-posts?evening=true", "schedule": "0 18 * * *" },
    { "path": "/api/cron-newsletter", "schedule": "0 14 * * *" }
  ]
}
