{
  "functions": {
    "api/log-results.js": {
      "maxDuration": 60
    },
    "api/picks-status.js": {
      "maxDuration": 60
    },
    "api/cron-newsletter.js": {
      "maxDuration": 300
    }
  },
  "redirects": [
    {
      "source": "/api/:path*",
      "has": [{ "type": "host", "value": "trueoddsiq.com" }],
      "destination": "https://www.trueoddsiq.com/api/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/cron-midday-post", "destination": "/api/cron-posts" },
    { "source": "/api/cron-evening-post", "destination": "/api/cron-posts?evening=true" },
    { "source": "/api/cron-blogs-weekly", "destination": "/api/cron-blogs?weekly=true" },
    { "source": "/api/cron-newsletter-generate", "destination": "/api/cron-newsletter?step=generate" },
    { "source": "/api/cron-newsletter-send", "destination": "/api/cron-newsletter?step=send" },
    { "source": "/api/cron-newsletter-send-catchup", "destination": "/api/cron-newsletter?step=send&catchup=true" },
    { "source": "/api/cron-newsletter-social", "destination": "/api/cron-newsletter?step=social" },
    { "source": "/api/cron-newsletter-catchup", "destination": "/api/cron-newsletter?step=send&catchup=true" },
    { "source": "/api/cron-grade-early", "destination": "/api/log-results" },
    { "source": "/api/cron-grade-midday", "destination": "/api/log-results" },
    { "source": "/api/cron-grade-evening", "destination": "/api/log-results" },
    { "source": "/api/billing", "destination": "/api/picks-status" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron-newsletter-generate", "schedule": "0 14 * * *" },
    { "path": "/api/cron-newsletter-send", "schedule": "30 14 * * *" },
    { "path": "/api/cron-newsletter-send-catchup", "schedule": "45 14 * * *" },
    { "path": "/api/cron-newsletter-social", "schedule": "50 14 * * *" },
    { "path": "/api/cron-blogs", "schedule": "0 7 * * *" },
    { "path": "/api/cron-blogs-weekly", "schedule": "0 8 * * 1" },
    { "path": "/api/cron-midday-post", "schedule": "0 12 * * *" },
    { "path": "/api/cron-evening-post", "schedule": "0 18 * * *" },
    { "path": "/api/cron-grade-early", "schedule": "0 5 * * *" },
    { "path": "/api/cron-grade-midday", "schedule": "30 12 * * *" },
    { "path": "/api/cron-grade-evening", "schedule": "30 18 * * *" }
  ]
}
